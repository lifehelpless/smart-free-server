<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.admin.module.business.membership.dao.MemberOrderDao">

    <!-- 查询结果列 -->
    <sql id="base_columns">
        t_membership_order.id,
        t_membership_order.order_no,
        t_membership_order.user_id,
        t_membership_order.goods_id,
        t_membership_order.goods_name,
        t_membership_order.order_amount,
        t_membership_order.status,
        t_membership_order.create_time,
        t_membership_order.update_time
    </sql>

    <!-- 分页查询 -->
    <select id="queryPage" resultType="net.lab1024.sa.admin.module.business.membership.domain.vo.MemberOrderVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_membership_order
        <where>
            <!--订单号-->
            <if test="queryForm.orderNo != null and queryForm.orderNo != ''">
                AND INSTR(t_order.order_no,#{queryForm.orderNo})
            </if>
        </where>
    </select>


</mapper>
